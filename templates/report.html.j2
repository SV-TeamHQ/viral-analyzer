<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>IG Competitor Research Report — {{ date_str }}</title>
  <style>
    :root {
      --bg: #0f1115; --card: #1a1d24; --ink: #e7e9ee; --dim: #9aa0aa;
      --accent: #e1306c; --accent2: #833ab4; --line: #2a2e37;
    }
    * { box-sizing: border-box; }
    body { margin: 0; background: var(--bg); color: var(--ink);
      font-family: -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.5; }
    .wrap { max-width: 980px; margin: 0 auto; padding: 32px 20px 80px; }
    h1 { font-size: 28px; margin: 0 0 4px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      -webkit-background-clip: text; background-clip: text; color: transparent; }
    .meta { color: var(--dim); font-size: 14px; margin-bottom: 24px; }
    .summary { background: var(--card); border: 1px solid var(--line);
      border-radius: 12px; padding: 20px; margin-bottom: 28px; }
    .summary h2 { margin: 0 0 8px; font-size: 18px; }
    .card { background: var(--card); border: 1px solid var(--line);
      border-radius: 14px; padding: 20px; margin-bottom: 18px; display: grid;
      grid-template-columns: 90px 1fr; gap: 18px; }
    .rank { font-size: 40px; font-weight: 800; color: var(--accent);
      text-align: center; align-self: start; }
    .thumb { display: block; margin: 10px auto 0; max-width: 100%;
      max-height: 560px; width: auto; height: auto; object-fit: contain;
      border-radius: 8px; }
    .handle { font-weight: 700; font-size: 16px; }
    .metrics { color: var(--dim); font-size: 13px; margin: 4px 0 12px;
      display: flex; gap: 14px; flex-wrap: wrap; }
    .metrics .outlier { color: var(--accent); font-weight: 700; }
    .hook { font-style: italic; color: #cdd2da; margin: 0 0 12px;
      border-left: 3px solid var(--accent2); padding-left: 12px; }
    .field { margin: 8px 0; }
    .field .label { color: var(--dim); font-size: 12px; text-transform: uppercase;
      letter-spacing: .04em; }
    details { margin-top: 10px; }
    summary { cursor: pointer; color: var(--dim); font-size: 13px; }
    .link { display: inline-block; margin-top: 12px; color: var(--accent);
      text-decoration: none; font-weight: 600; }
    .link:hover { text-decoration: underline; }
    .placeholder { color: var(--dim); font-style: italic; }
    .patterns { border-color: var(--accent2); }
    .patterns h2 { margin-bottom: 10px; }
    .pattern-block { margin-top: 14px; }
    .pattern-block .label { margin-bottom: 6px; }
    .hook-type { background: #15171c; border: 1px solid var(--line); border-radius: 6px;
      margin-bottom: 6px; }
    .hook-type > .ht-head { padding: 8px 10px; font-size: 13px; }
    .hook-type > .ht-body { border-top: 1px solid var(--line); padding: 8px 10px;
      font-size: 12px; color: var(--dim); }
    .hook-type .ht-body ul { margin: 4px 0 0 16px; padding: 0; color: #cdd2da; line-height: 1.5; }
    .fmt-row { display: flex; align-items: center; gap: 8px; margin-bottom: 3px; font-size: 12px; }
    .fmt-name { width: 120px; display: inline-block; }
    .fmt-bar { height: 6px; border-radius: 3px; display: inline-block; }
    .spoken-hook { background: #15171c; border-left: 3px solid var(--accent);
      border-radius: 4px; padding: 8px 10px; margin: 0 0 12px; }
    .spoken-hook .sh-tag { color: var(--accent); font-size: 11px; }
    .spoken-hook .sh-chip { background: var(--line); color: #cdd2da; font-size: 10px;
      padding: 1px 6px; border-radius: 8px; }
    .spoken-hook .sh-win { color: var(--dim); font-size: 10px; }
    .spoken-hook .sh-text { font-style: italic; color: var(--ink); font-size: 13px; }

    /* Print / PDF: light theme (Chromium's page.pdf renders with print media).
       Screen viewing keeps the dark theme above. */
    @media print {
      :root {
        --bg: #ffffff;
        --card: #f7f8fa;
        --ink: #1a1d24;
        --dim: #555c66;
        --line: #d9dde3;
        --accent: #b3245f;
        --accent2: #6f2e8a;
      }
      body { background: #ffffff; }
      .wrap { padding: 0; }
      /* the gradient/transparent h1 doesn't render reliably in print — use a solid tone */
      h1 {
        background: none;
        -webkit-text-fill-color: #b3245f;
        color: #b3245f;
      }
      .hook { color: #2a2e37; }          /* override the light-on-dark hook text */
      .card { break-inside: avoid; }      /* don't split a card across PDF pages */
    }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>IG Competitor Research Report</h1>
    <div class="meta">
      Generated: {{ date_str }} &middot;
      Handles: {{ handles | join(", ") }} &middot;
      Posts: {{ total }}
    </div>

    <section class="summary patterns">
      <h2>🔥 What's Working in the Niche</h2>
      <p>{{ summary }}</p>

      {% if patterns %}
      <div class="pattern-block">
        <h3 style="margin:0 0 8px;font-size:15px;">Niche Patterns</h3>
        <div class="label">Top hook structures</div>
        {% for ht in patterns.hook_types or [] %}
        <div class="hook-type">
          <div class="ht-head"><strong style="color:var(--accent);">{{ loop.index }}. {{ ht.name }}</strong> · {{ ht.count }} posts ({{ "{:.0%}".format(ht.share) }})</div>
          <div class="ht-body">
            <em>Definition:</em> {{ ht.definition }}
            <div style="margin-top:4px;"><em>How it was executed:</em></div>
            <ul>
              {% for ex in ht.examples or [] %}
              <li><strong>@{{ ex.handle }}</strong> — {{ ex.execution }} <span style="color:var(--accent);">{{ ex.outlier_score }}x</span></li>
              {% endfor %}
            </ul>
          </div>
        </div>
        {% endfor %}

        {% if patterns.formats %}
        <div class="label" style="margin-top:10px;">Dominant formats</div>
        {% for f in patterns.formats %}
        <div class="fmt-row">
          <span class="fmt-name">{{ f.name }}</span>
          <span class="fmt-bar" style="width: {{ "{:.0%}".format(f.share) }}; background: {% if loop.index0 == 0 %}var(--accent){% else %}var(--accent2){% endif %};"></span>
          <span style="color:var(--dim);">{{ "{:.0%}".format(f.share) }}</span>
        </div>
        {% endfor %}
        {% endif %}

        {% if patterns.topics %}
        <div class="label" style="margin-top:10px;">Recurring topics</div>
        <p style="font-size:13px;color:#cdd2da;">{{ patterns.topics | join(" · ") }}</p>
        {% endif %}
      </div>
      {% endif %}
    </section>

    {% for post in posts %}
    <article class="card">
      <div class="rank">#{{ post.rank }}</div>
      <div>
        <div class="handle">@{{ post.handle }}</div>
        <div class="metrics">
          <span>❤️ {{ "{:,}".format(post.likes) }}</span>
          <span>💬 {{ "{:,}".format(post.comments) }}</span>
          {% if post.views %}<span>👁️ {{ "{:,}".format(post.views) }}</span>{% endif %}
          <span class="outlier">⚡ {{ post.outlier_score }}x outlier</span>
        </div>

        {% if post.thumbnail %}
          <img class="thumb" src="{{ post.thumbnail }}" alt="frame for @{{ post.handle }}">
        {% endif %}

        {% if post.spoken_hook %}
        <div class="spoken-hook">
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;flex-wrap:wrap;">
            <span class="sh-tag">▶ SPOKEN HOOK</span>
            <span class="sh-chip">{{ post.spoken_hook.type }}</span>
            <span class="sh-win">{{ post.spoken_hook.window }}</span>
          </div>
          <div class="sh-text">"{{ post.spoken_hook.text }}"</div>
        </div>
        {% endif %}

        {% if post.analyzed %}
          {% if post.hook %}<p class="hook">"{{ post.hook }}"</p>{% endif %}
          {% if post.visual_format %}<div class="field"><div class="label">Format</div><div>{{ post.visual_format }}</div></div>{% endif %}
          {% if post.format_breakdown %}<div class="field"><div class="label">Format Breakdown</div><div>{{ post.format_breakdown }}</div></div>{% endif %}
          {% if post.topic %}<div class="field"><div class="label">Topic</div><div>{{ post.topic }}</div></div>{% endif %}
          {% if post.why_it_worked %}<div class="field"><div class="label">Why It Worked</div><div>{{ post.why_it_worked }}</div></div>{% endif %}
          {% if post.replication_notes %}<div class="field"><div class="label">Replication Notes</div><div>{{ post.replication_notes }}</div></div>{% endif %}
          {% if post.transcript %}
          <details><summary>Transcript</summary><p>{{ post.transcript }}</p></details>
          {% endif %}
        {% else %}
          <p class="placeholder">{{ post.why_it_worked }}</p>
        {% endif %}

        <a class="link" href="{{ post.url }}" target="_blank" rel="noopener">View Original Post →</a>
      </div>
    </article>
    {% endfor %}
  </div>
</body>
</html>
